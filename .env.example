# Port the server listens on. Render (and most hosts) inject this automatically —
# only set it yourself for local development if you need a port other than 5050.
PORT=5050

# Optional: when set, marking a test run result "failed" auto-files a GitHub issue
# in this repo using this token (see server/routes/test-runs.js). If either is
# unset, issue-filing is silently skipped — no crash, no error.
GITHUB_TOKEN=
GITHUB_ISSUES_REPO=owner/repo
